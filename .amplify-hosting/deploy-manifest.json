{
  "version": 1,
  "routes": [
    {
      "path": "/_nuxt/<*>",
      "target": {
        "kind": "Static"
      }
    },
    {
      "path": "/<*>",
      "target": {
        "kind": "Static"
      },
      "fallback": {
        "kind": "StaticFile",
        "uri": "/index.html"
      }
    }
  ]
}
